@language Simon
@import 'ui'
@import 'im-metamodel'

package DAUI {
    objectTypes {
        objectType IEntityComponent {
            superTypes: UI.IComponent
            references {
                reference entity { type: IM.Entity }
            }
        }
        objectType EntityScreen {
            superTypes: UI.Screen
            superTypes: IEntityComponent
        }
    }
}
