@language Simon
/* Primitives for metamodels */
Package primitives2 {
    primitiveTypes {
        PrimitiveType String (kind: String)
        PrimitiveType Integer (kind: Integer)
        PrimitiveType int (kind: Integer)
        PrimitiveType Boolean (kind: Boolean)
        PrimitiveType boolean (kind: Boolean)
        PrimitiveType Decimal (kind: Decimal)
    }
}
